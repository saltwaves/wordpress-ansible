server {
    listen 80{% if nginx_default_server | bool %} default_server{% endif %};
    listen [::]:80{% if nginx_default_server | bool %} default_server{% endif %};

    server_name {{ wordpress_domains | join(' ') }};
    root {{ wordpress_web_root }};
    index index.php index.html;

    client_max_body_size {{ php_upload_max_filesize }};

    access_log /var/log/nginx/{{ wordpress_site_name }}.access.log;
    error_log /var/log/nginx/{{ wordpress_site_name }}.error.log;

    location = /favicon.ico {
        log_not_found off;
        access_log off;
    }

    location = /robots.txt {
        allow all;
        log_not_found off;
        access_log off;
    }

    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php{{ php_version }}-fpm.sock;
    }

    location ~* \.(?:css|js|jpg|jpeg|gif|png|webp|avif|ico|svg|woff2?)$ {
        expires max;
        log_not_found off;
    }

    location ~* /(?:uploads|files)/.*\.php$ {
        deny all;
    }

    location ~ /\. {
        deny all;
    }
}
